---
import Layout from "../layouts/Layout.astro";
import { publicServices } from "../data/services";

const serviceIcons: Record<string, string> = {
  "custom-synthesis": "🧪",
  "custom-manufacturing": "🏭",
  "process-development": "⚗️",
  "contract-rd": "🔬",
  "bulk-chemicals": "📦",
};
---
<Layout title="Services" description="CHEM-IS-TRY, Inc. offers custom synthesis, manufacturing, process development, contract R&D, and cGMP services.">

  <div class="page-hero">
    <h1>Our Services</h1>
    <p>From custom synthesis to bulk manufacturing — chemistry guaranteed.</p>
  </div>

  <div class="container">
    <div class="page-content">

      <p style="font-size:1.05rem;margin-bottom:2rem;">
        CHEM-IS-TRY, Inc. offers comprehensive chemical services to the research, pharmaceutical,
        and industrial communities. Our in-house team of PhD and MS chemists bring decades of
        expertise to every project.
      </p>

      <div class="services-grid">
        {publicServices.map((service) => (
          <div class="service-card">
            <h3>{serviceIcons[service.slug]} {service.title}</h3>
            <p>{service.shortDescription}</p>
            <a href={`/services/${service.slug}/`} class="learn-more">Learn more →</a>
          </div>
        ))}
      </div>

      <div style="margin-top:3rem;background:var(--blue-pale);padding:2rem;border-radius:var(--radius);text-align:center;">
        <h3 style="color:var(--blue);margin-bottom:.75rem;">Ready to Start a Project?</h3>
        <p style="margin-bottom:1.25rem;color:var(--gray-600);">Submit a Request for Quotation and our team will evaluate your project within 2–3 business days.</p>
        <a href="/rfq/" class="btn btn-primary">Request for Quotation</a>
      </div>

    </div>
  </div>
</Layout>
