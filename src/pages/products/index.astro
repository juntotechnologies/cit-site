---
import Layout from "../../layouts/Layout.astro";
import { getProductPath } from "../../lib/product-url.js";
import { parseProducts, CIT_LABEL } from "../../types/product";
import rawProducts from "../../../data/products.json";

const productsData = parseProducts(rawProducts as unknown[]);
const productViewData = productsData.map((product) => ({
  ...product,
  product_path: getProductPath(product, productsData),
}));

const cats = [
  { value: "",              label: "All Categories" },
  { value: "organic",       label: "Organic" },
  { value: "inorganic",     label: "Inorganic" },
  { value: "reagent-usp",   label: "Reagent / USP" },
  { value: "representative",label: "Representative Products" },
  { value: "bulk",          label: "Bulk Chemicals" },
];
---
<Layout title="Product Catalog" description="Browse 1,000+ chemical products — organic, inorganic, reagent/USP, and bulk chemicals.">

  <div class="page-hero">
    <h1>Product Catalog</h1>
    <p>Organic, inorganic, reagent/USP, and bulk chemicals</p>
  </div>

  <div class="container">
    <div class="section">

      <div class="search-filter-bar">
        <input
          type="search"
          id="product-search"
          placeholder="Search by name, CAS#, formula, or catalog number..."
          autocomplete="off"
        />
        <select id="cat-filter" aria-label="Filter by category">
          {cats.map(c => <option value={c.value}>{c.label}</option>)}
        </select>
      </div>

      <p class="search-count" id="search-count"></p>
      <div class="product-grid" id="product-grid"></div>
      <div class="pagination" id="pagination"></div>

    </div>
  </div>
</Layout>

<script define:vars={{ products: productViewData, CIT_LABEL }}>
  // define:vars scripts are always rendered inline (Astro never bundles
  // them), so they can't use `import`. Hand the data off to the bundled
  // script below via a page-scoped global instead.
  window.__PRODUCT_SEARCH_DATA__ = { products, CIT_LABEL };
</script>
<script>
  // Deliberately no `type="module"` here: Astro bundles plain <script>
  // tags (adding type="module" itself), but an explicitly-authored
  // type="module" is left untouched/unbundled, which would ship a raw,
  // unresolvable `import` straight to the browser.
  import { initProductSearch } from "../../lib/product-search.js";
  const { products, CIT_LABEL } = window.__PRODUCT_SEARCH_DATA__;
  initProductSearch(products, CIT_LABEL);
</script>
