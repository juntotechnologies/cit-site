---
import Layout from "../../layouts/Layout.astro";
import { formulaToHtml } from "../../lib/formula";
import productsData from "../../../data/products.json";

export function getStaticPaths() {
  return productsData.map((p) => {
    const slug = p.catalog_number
      ? p.catalog_number.toLowerCase()
      : p.name?.toLowerCase().replace(/[^\w\s-]/g, "").replace(/[\s_-]+/g, "-").replace(/^-+|-+$/g, "") || "unknown";
    return { params: { slug }, props: { product: p } };
  });
}

const { product: p } = Astro.props;

const productDesc = `${p.name} — CAS ${p.cas || "N/A"}, MW ${p.molecular_weight || "N/A"}. Chemical catalog product from CHEM-IS-TRY, Inc.`;
const ogImage = p.image_file
  ? `https://chem-is-try.com/images/${p.image_file}`
  : "https://chem-is-try.com/assets/banner-01.jpg";

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": p.name,
  "description": p.description || productDesc,
  "image": ogImage,
  "brand": {
    "@type": "Organization",
    "name": "CHEM-IS-TRY, Inc."
  },
  ...(p.cas && { "identifier": p.cas }),
  "additionalProperty": [
    ...(p.cas ? [{ "@type": "PropertyValue", "name": "CAS Number", "value": p.cas }] : []),
    ...(p.molecular_formula ? [{ "@type": "PropertyValue", "name": "Molecular Formula", "value": p.molecular_formula }] : []),
    ...(p.molecular_weight ? [{ "@type": "PropertyValue", "name": "Molecular Weight", "value": `${p.molecular_weight} g/mol` }] : []),
    ...(p.purity ? [{ "@type": "PropertyValue", "name": "Purity", "value": p.purity }] : []),
    ...(p.catalog_number ? [{ "@type": "PropertyValue", "name": "Catalog Number", "value": p.catalog_number }] : []),
  ].filter(Boolean),
  "offers": {
    "@type": "Offer",
    "url": `https://chem-is-try.com/rfq/?product=${encodeURIComponent(p.name || "")}`,
    "seller": { "@type": "Organization", "name": "CHEM-IS-TRY, Inc." }
  }
});
---
<Layout
  title={p.name || "Product"}
  description={productDesc}
  ogImage={ogImage}
  ogType="product"
>
  <script type="application/ld+json" set:html={productSchema} slot="head" />
  <div class="container">
    <div class="product-detail">
      <p class="breadcrumb">
        <a href="/">Home</a> › <a href="/products/">Products</a> › {p.name}
      </p>

      <div class="product-layout">
        <!-- Structure image -->
        <div>
          <div class="product-structure">
            {p.image_file
              ? <img src={`/images/${p.image_file}`} alt={`Structure of ${p.name}`} />
              : <p style="color:var(--gray-400);padding:2rem">No structure image available</p>
            }
          </div>
          <div class="rfq-cta mt-2">
            <p>Interested in this product?</p>
            <a href={`/rfq/?product=${encodeURIComponent(p.name || "")}&cat=${encodeURIComponent(p.catalog_number || "")}&cas=${encodeURIComponent(p.cas || "")}`} class="btn btn-primary">
              Request a Quote
            </a>
          </div>
        </div>

        <!-- Product info -->
        <div class="product-info">
          <h1>{p.name}</h1>

          <table class="product-table">
            {p.catalog_number && (
              <tr><th>Catalog #</th><td>{p.catalog_number}</td></tr>
            )}
            {p.cas && (
              <tr><th>CAS Number</th><td>{p.cas}</td></tr>
            )}
            {p.molecular_formula && (
              <tr>
                <th>Molecular Formula</th>
                <td set:html={formulaToHtml(p.molecular_formula)} />
              </tr>
            )}
            {p.molecular_weight && (
              <tr><th>Molecular Weight</th><td>{p.molecular_weight} g/mol</td></tr>
            )}
            {p.purity && (
              <tr><th>Purity</th><td>{p.purity}</td></tr>
            )}
            {p.grade && (
              <tr><th>Grade</th><td>{p.grade}</td></tr>
            )}
            {p.synonyms && (
              <tr><th>Synonyms</th><td>{p.synonyms}</td></tr>
            )}
          </table>

          {p.description && (
            <div>
              <h2 style="font-size:1rem;color:var(--gray-600);margin-bottom:.5rem">Description</h2>
              <p style="color:var(--gray-600);font-size:.9rem">{p.description}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>
