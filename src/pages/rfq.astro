---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Request for Quotation" description="Submit a Request for Quotation for any CHEM-IS-TRY product. We respond within 2–3 business days.">

  <div class="page-hero">
    <h1>Request for Quotation</h1>
    <p>Fill out the form below — we'll respond with pricing and availability within 2–3 business days.</p>
  </div>

  <div class="container">
    <div class="page-content" style="max-width:820px;">

      <form
        class="rfq-form"
        id="rfq-form"
        action="https://formspree.io/f/xyknboky"
        method="POST"
      >

        <p class="form-section-title">Chemical Details</p>
        <div class="form-row">
          <div class="form-group">
            <label for="chem-name">Chemical Name *</label>
            <input type="text" id="chem-name" name="chemical_name" required />
          </div>
          <div class="form-group">
            <label for="cit-num">CIT # (Catalog Number)</label>
            <input type="text" id="cit-num" name="catalog_number" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="cas-num">CAS #</label>
            <input type="text" id="cas-num" name="cas_number" />
          </div>
          <div class="form-group">
            <label for="quantity">Quantity Required</label>
            <input type="text" id="quantity" name="quantity" placeholder="e.g. 100g, 1kg" />
          </div>
        </div>

        <p class="form-section-title">Contact Details</p>
        <div class="form-row">
          <div class="form-group">
            <label for="rfq-name">Name *</label>
            <input type="text" id="rfq-name" name="name" required />
          </div>
          <div class="form-group">
            <label for="rfq-company">Company</label>
            <input type="text" id="rfq-company" name="company" />
          </div>
        </div>
        <div class="form-group">
          <label for="rfq-email">Email Address *</label>
          <input type="email" id="rfq-email" name="email" required />
        </div>
        <div class="form-group">
          <label for="rfq-address">Address</label>
          <input type="text" id="rfq-address" name="address" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="rfq-tel">Telephone</label>
            <input type="tel" id="rfq-tel" name="telephone" />
          </div>
          <div class="form-group">
            <label for="rfq-fax">Fax</label>
            <input type="text" id="rfq-fax" name="fax" />
          </div>
        </div>
        <div class="form-group">
          <label for="rfq-comments">Comments / Additional Requirements</label>
          <textarea id="rfq-comments" name="comments" placeholder="Purity requirements, delivery timeline, any other specifications..."></textarea>
        </div>

        <input type="hidden" name="_subject" value="RFQ Submission – chem-is-try.com" />
        <input type="text" name="_gotcha" style="display:none" />

        <button type="submit" class="btn btn-primary" style="font-size:1rem;padding:.75rem 2rem;">Submit Request</button>
        <div class="form-success" id="rfq-success">
          Thank you! Your request has been received. We will respond within 2–3 business days.
        </div>
      </form>


    </div>
  </div>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("rfq-form") as HTMLFormElement | null;
    if (!form) return;

    // Pre-fill from URL params (must run client-side on a static site)
    const params = new URLSearchParams(location.search);
    const prefill: Record<string, string> = {
      "chem-name": params.get("product") || "",
      "cit-num":   params.get("cat")     || "",
      "cas-num":   params.get("cas")     || "",
    };
    for (const [id, val] of Object.entries(prefill)) {
      if (val) {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) el.value = val;
      }
    }

    const succ = document.getElementById("rfq-success") as HTMLDivElement | null;
    form.addEventListener("submit", async e => {
      e.preventDefault();
      const r = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { Accept: "application/json" }});
      if (r.ok) {
        form.reset();
        if (succ) succ.style.display = "block";
        form.querySelector<HTMLButtonElement>("button")!.style.display = "none";
      }
    });
  });
</script>
