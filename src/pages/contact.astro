---
import Layout from "../layouts/Layout.astro";
import { COMPANY, TEAM } from "../config/company";
---
<Layout title="Contact Us" description="Contact CHEM-IS-TRY, Inc. – our team is ready to assist with product inquiries and quotation requests.">

  <div class="page-hero">
    <h1>Contact Us</h1>
    <p>Our team is here to help with product inquiries, quotes, and technical support.</p>
  </div>

  <div class="container">
    <div class="page-content">

      <!-- Team directory -->
      <h2>Our Team</h2>
      <div class="team-grid">
        {TEAM.map(m => (
          <div class="team-card">
            <h3>{m.name}</h3>
            <p class="title">{m.title}</p>
            <a href={`mailto:${m.email}`}>{m.email}</a>
          </div>
        ))}
      </div>

      <!-- Contact info + form -->
      <div class="contact-info-grid">
        <div class="info-box">
          <h3>Contact Information</h3>
          <div class="info-row"><span class="label">General</span><a href={`mailto:${COMPANY.email}`}>{COMPANY.email}</a></div>
          <div class="info-row"><span class="label">Address</span><span>{COMPANY.address.full}</span></div>
          <div class="info-row"><span class="label">Phone</span><span>{COMPANY.phoneDisplay}</span></div>
          <div class="info-row"><span class="label">Toll Free</span><span>{COMPANY.tollFreeDisplay}</span></div>
          <div class="info-row"><span class="label">Fax</span><span>{COMPANY.faxDisplay}</span></div>
          <div class="info-row"><span class="label">ChemTrec</span><span>{COMPANY.chemtrec}</span></div>
        </div>

        <div>
          <h3 style="color:var(--blue);margin-bottom:1rem;">Send a Message</h3>
          <form
            id="contact-form"
            action="https://formspree.io/f/mbdzpwoq"
            method="POST"
          >
            <div class="form-group">
              <label for="c-name">Name *</label>
              <input type="text" id="c-name" name="name" required />
            </div>
            <div class="form-group">
              <label for="c-company">Company</label>
              <input type="text" id="c-company" name="company" />
            </div>
            <div class="form-group">
              <label for="c-email">Email *</label>
              <input type="email" id="c-email" name="email" required />
            </div>
            <div class="form-group">
              <label for="c-phone">Phone</label>
              <input type="tel" id="c-phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="c-message">Comments *</label>
              <textarea id="c-message" name="message" required></textarea>
            </div>
            <input type="hidden" name="_subject" value="Contact form submission – chem-is-try.com" />
            <input type="text" name="_gotcha" style="display:none" />
            <button type="submit" class="btn btn-primary">Send Message</button>
            <div class="form-success" id="c-success">Thank you! We'll be in touch shortly.</div>
          </form>
        </div>
      </div>

      <!-- Live Map -->
      <div style="margin-top:2.5rem;">
        <h3 style="color:var(--blue);margin-bottom:1rem;">Our Location</h3>
        <iframe
          src={COMPANY.mapEmbedUrl}
          width="100%"
          height="350"
          style="border:0;border-radius:var(--radius);display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="CHEM-IS-TRY Inc. location map"
        ></iframe>
      </div>

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const succ = document.getElementById("c-success") as HTMLDivElement;
  form?.addEventListener("submit", async e => {
    e.preventDefault();
    const r = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { Accept: "application/json" }});
    if (r.ok) { form.reset(); succ.style.display = "block"; }
  });
</script>
